# Configuração de Credenciais para Sincronização CPI/SAP PO
# 
# ATENÇÃO: Este arquivo contém informações sensíveis!
# Adicione este arquivo ao .gitignore e nunca o versione.
#
# Opções de uso:
# 1. Definir variáveis de ambiente antes de rodar a aplicação
# 2. Carregar via arquivo .env (recomendado)
# 3. Usar Docker Secrets em ambiente de produção

# ============================================
# SAP CPI Configuration
# ============================================

# Host do SAP CPI (sem https://)
CPI_HOST=seu_host

# Usuário técnico/conta de serviço do CPI
CPI_USERNAME=seu_usuario_aqui

# Senha da conta CPI
CPI_PASSWORD=sua_senha_aqui

# ID do Tenant CPI
# Geralmente é o mesmo prefixo da URL
# Ex: https://xxxxxxx-tmn... → tenant = xxxxxx
CPI_TENANT_ID=xxxxxxx

# ============================================
# SAP PO Configuration (Opcional)
# ============================================

# Host do SAP PO/Integration Engine
# SAP_PO_HOST=seu_servidor_po.example.com

# SAP PO System Client (default: 100)
# SAP_PO_CLIENT=100

# SAP PO Username
# SAP_PO_USERNAME=usuario_po

# SAP PO Password
# SAP_PO_PASSWORD=senha_po

# ============================================
# GDEP Configuration
# ============================================

# Ambiente da aplicação: development, staging, production
ENVIRONMENT=development

# Segredo usado para criptografia e sessão (OBRIGATÓRIO em produção)
APP_SECRET=gere_um_valor_forte_e_unico

# URL base da API GDEP (padrão: http://127.0.0.1:8000)
GDEP_API_URL=http://127.0.0.1:8000

# Credenciais de login no GDEP para o utilitário sync_cpi.py
GDEP_USER_EMAIL=seu_usuario@empresa.com
GDEP_USER_PASSWORD=sua_senha_gdep

# CORS (separar múltiplas origens por vírgula)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Cookie seguro (true em produção com HTTPS)
COOKIE_SECURE=false

# Domínio do cookie de sessão (opcional)
# COOKIE_DOMAIN=.empresa.com

# Habilita scheduler no processo atual (em múltiplas réplicas, deixar true apenas em uma)
SCHEDULER_ENABLED=true

# Limites de taxa para reduzir abuso
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
SYNC_RATE_LIMIT_ATTEMPTS=6
SYNC_RATE_LIMIT_WINDOW_SECONDS=600

# Verificação TLS do SAP PO
PO_VERIFY_SSL=true

# PostgreSQL para execução via Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=trocar_esta_senha
POSTGRES_DB=integration_governance

# ============================================
# Sincronização Automática
# ============================================

# Habilitar sincronização automática (True/False)
# AUTO_SYNC_ENABLED=True

# Intervalo de sincronização em horas (padrão: 24)
# AUTO_SYNC_INTERVAL_HOURS=24

# Horário de execução (HH:MM em UTC)
# AUTO_SYNC_TIME=02:00

# ============================================
# Logging
# ============================================

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Arquivo de log para sincronizações
LOG_FILE=./logs/cpi_sync.log
